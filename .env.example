# Aijolot Banner Agent environment example
# Copy to .env.local for local development. Never commit real secrets.

# Supabase local defaults from `supabase start`
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
SUPABASE_ANON_KEY=replace-with-output-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=replace-with-output-from-supabase-start
SUPABASE_STORAGE_BUCKET=campaign-assets

# Frontend
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-output-from-supabase-start
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Google / Gemini / ADK
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_IMAGE=gemini-2.5-flash-image
IMAGE_GENERATION_PROVIDER=gemini
SOFT_IMAGE_GENERATION_LIMIT_PER_15_MINUTES=20

# Shopify local/custom app token access
SHOPIFY_SHOP_DOMAIN=maison-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
SHOPIFY_THEME_ID=
SHOPIFY_BANNER_METAFIELD_NAMESPACE=aijolot
SHOPIFY_BANNER_METAFIELD_KEY=banner_campaigns

APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
