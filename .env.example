# Aijolot Banner Agent environment example
# Copy to .env.local for local development. Never commit real secrets.

# Supabase local defaults from `supabase start`
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
SUPABASE_ANON_KEY=replace-with-output-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=replace-with-output-from-supabase-start
BRAND_CONTEXT_TEAM_ID=
SUPABASE_TEAM_ID=
SUPABASE_STORE_ID=
SUPABASE_STORAGE_BUCKET=campaign-assets

# DB migrations on container boot (scripts/apply-migrations.sh).
# The deployed image forward-migrates the persistent self-hosted DB to match
# supabase/migrations/ before serving. Leave 0 for local dev (which uses
# `supabase db reset`). In the deployed runtime env set RUN_DB_MIGRATIONS=1.
# First run against an existing, untracked DB: set DB_MIGRATIONS_BASELINE to
# the last version already applied so earlier migrations are marked done
# instead of re-run (demo cutover: 20260603210000).
RUN_DB_MIGRATIONS=0
DB_MIGRATIONS_BASELINE=

# Frontend
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-output-from-supabase-start
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Google / Gemini / ADK
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL_PRO=gemini-3.1-pro
GEMINI_MODEL_FLASH=gemini-3.5-flash
GEMINI_MODEL_IMAGE=gemini-3.1-pro-image
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
IMAGE_GENERATION_PROVIDER=gemini

# C2 — video banners (Veo). EXPENSIVE (~$0.40/s): double-gated behind this flag
# and the cost guard. Unset provider resolves to the deterministic fake.
VIDEO_GENERATION_ENABLED=false
VIDEO_GENERATION_PROVIDER=
SOFT_IMAGE_GENERATION_LIMIT_PER_15_MINUTES=20
DAILY_COST_CAP_USD=5.0
KG_RETRIEVAL_TOP_K=5
KG_SIMILARITY_THRESHOLD=0.65

# Agentic provider opt-ins (empty = deterministic; "gemini" = Gemini-backed
# with GOOGLE_API_KEY, still falls back to deterministic on error/cost cap).
AIJOLOT_INTAKE_PROVIDER=
AIJOLOT_CONCEPT_PROVIDER=
AIJOLOT_BACKGROUND_PROVIDER=
AIJOLOT_REFINE_PROVIDER=
# Use Gemini embeddings + pgvector RPC for KG retrieval (requires seeded kg_documents).
KG_EMBEDDINGS_ENABLED=false

# Shopify local/custom app token access
SHOPIFY_SHOP_DOMAIN=maison-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01
SHOPIFY_THEME_ID=
SHOPIFY_BANNER_METAFIELD_NAMESPACE=aijolot
SHOPIFY_BANNER_METAFIELD_KEY=banner_campaigns
# Safety: when true, publish/unpublish compute + record the job but never mutate Shopify.
SHOPIFY_PUBLISH_DRY_RUN=true

APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
